# ===========================================
# 数字开奖管理系统 - 环境变量配置
# ===========================================
# 复制此文件为 .env 并填入实际值

# ===========================================
# 必需配置（部署必须设置）
# ===========================================

# MongoDB 数据库连接字符串
# Vercel Integration 格式: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=

# JWT 签名密钥（用于生成和验证Token）
# 要求：至少32位随机字符串
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# 定时任务调用密钥（用于cron-job.org调用鉴权）
# 要求：至少16位随机字符串
CRON_SECRET=

# ===========================================
# 数据库配置（可选）
# ===========================================

# 数据库连接池大小
DB_POOL_SIZE=10

# 最小连接数
DB_MIN_POOL_SIZE=2

# 读偏好（用于副本集读写分离）
# 可选值: primary, primaryPreferred, secondary, secondaryPreferred, nearest
DB_READ_PREFERENCE=

# ===========================================
# Redis 缓存配置（可选）
# ===========================================

# Redis 连接URL
# 标准格式: redis://localhost:6379
# 带密码: redis://:password@host:port
# Upstash格式: https://:password@endpoint.upstash.io
REDIS_URL=

# ===========================================
# 支付宝支付配置（可选）
# ===========================================

# 支付宝应用ID
ALIPAY_APP_ID=

# 支付宝公钥（用于验证回调签名）
ALIPAY_PUBLIC_KEY=

# 应用私钥（用于生成签名）
ALIPAY_PRIVATE_KEY=

# 是否启用支付宝代付
ALIPAY_PAYOUT_ENABLED=false

# 支付宝代付API地址
ALIPAY_PAYOUT_API_URL=

# ===========================================
# 微信支付配置（可选）
# ===========================================

# 微信应用ID
WECHAT_APP_ID=

# 微信商户号
WECHAT_MCH_ID=

# 微信API密钥（V2）
WECHAT_API_KEY=

# 微信API V3密钥
WECHAT_API_V3_KEY=

# 是否启用微信代付
WECHAT_PAYOUT_ENABLED=false

# 微信代付API地址
WECHAT_PAYOUT_API_URL=

# 微信证书路径（用于代付）
WECHAT_CERT_PATH=

# ===========================================
# 银行卡代付配置（可选）
# ===========================================

# 是否启用银行卡代付
BANK_PAYOUT_ENABLED=false

# 代付API地址
BANK_PAYOUT_API_URL=

# 代付API密钥
BANK_PAYOUT_API_KEY=

# 商户ID
BANK_MERCHANT_ID=

# ===========================================
# 日志配置（可选）
# ===========================================

# 日志服务类型: console, axiom, logtail
LOG_SERVICE=console

# 日志级别: debug, info, warn, error
LOG_LEVEL=info

# Axiom 日志服务配置
AXIOM_DATASET=
AXIOM_TOKEN=

# Logtail 日志服务配置
LOGTAIL_SOURCE_TOKEN=

# 是否开启结构化日志
LOG_STRUCTURED=false

# ===========================================
# 安全配置（可选）
# ===========================================

# 允许的跨域来源（多个用逗号分隔）
# 开发环境: * (允许所有)
# 生产环境: https://yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS=*

# JWT Token 有效期（天）
JWT_EXPIRES_IN=7

# ===========================================
# 运行时配置（由系统自动设置，无需手动配置）
# ===========================================

# 项目工作目录
# COZE_WORKSPACE_PATH=/workspace/projects

# 对外访问域名
# COZE_PROJECT_DOMAIN_DEFAULT=https://xxx.vercel.app

# 服务监听端口
# DEPLOY_RUN_PORT=5000

# 运行环境: DEV 或 PROD
# COZE_PROJECT_ENV=DEV
