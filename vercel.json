{
  "rewrites": [
    { "source": "/api/auth", "destination": "/api/auth" },
    { "source": "/api/users", "destination": "/api/users" },
    { "source": "/api/transactions", "destination": "/api/transactions" },
    { "source": "/api/admin", "destination": "/api/admin" },
    { "source": "/api/system", "destination": "/api/system" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    }
  ]
}
